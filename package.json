{
  "name": "mu",
  "description": "軽量でミニマルなブラウザ",
  "author": {
    "name": "Ubsa",
    "email": "ubsa17@gmail.com"
  },
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun run build.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "tauri": "tauri",
    "test": "bun test",
    "format:front": "bunx --bun oxfmt",
    "lint:front": "bunx --bun oxlint",
    "lint:front:fix": "bunx --bun oxlint --fix",
    "check:front": "bun format:front && bun lint:front && tsc --noEmit",
    "check:front:fix": "bun format:front && bun lint:front:fix && tsc --noEmit",
    "format:back": "cd src-tauri && cargo fmt && cd ..",
    "lint:back": "cd src-tauri && cargo clippy && cd ..",
    "check:back": "bun format:back && bun lint:back",
    "format": "bun format:front && bun format:back",
    "lint": "bun lint:front && bun lint:back",
    "check": "bun check:front && bun check:back"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@simplestack/store": "^0.7.1",
    "@tauri-apps/cli": "^2.9.5",
    "bun-plugin-isolated-decl": "^0.2.8",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "fast-check": "^3.23.1",
    "happy-dom": "^20.0.11",
    "oxfmt": "^0.15.0",
    "oxlint": "^1.30.0",
    "oxlint-tsgolint": "^0.8.3",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}